{
  "name": "@vulhdev/knowledge-base",
  "version": "1.1.3",
  "description": "MCP server for persistent document storage with full-text search",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "knowledge-base": "dist/index.js",
    "knowledge-base-init": "dist/bin/init.js"
  },
  "files": [
    "dist",
    "skills"
  ],
  "keywords": [
    "mcp",
    "mcp-server",
    "knowledge-base",
    "sqlite",
    "claude",
    "claude-code"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vulhdev/knowledge-base.git"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "@modelcontextprotocol/sdk": "1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
